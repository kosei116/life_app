# PostgreSQL
DATABASE_URL=postgresql://scheduler:scheduler@localhost:5432/scheduler

# Backend
PORT=3030
NODE_ENV=development

# GAS (Google Apps Script Web App)
GAS_ENDPOINT=https://script.google.com/macros/s/XXXXXXXX/exec
GAS_SHARED_SECRET=

# Sync window (months relative to today)
SYNC_WINDOW_PAST_MONTHS=1
SYNC_WINDOW_FUTURE_MONTHS=6
