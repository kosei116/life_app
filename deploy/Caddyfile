# life_app Caddy 設定（IPアクセス・パス分け）

:80 {
	encode gzip zstd

	# ルート → scheduler にリダイレクト
	@root path /
	redir @root /scheduler/ 302

	# === scheduler ===
	# /scheduler/api/* は /api/* にしてバックエンドへ
	handle /scheduler/api/* {
		uri strip_prefix /scheduler
		reverse_proxy localhost:3030
	}
	handle_path /scheduler/* {
		root * /srv/life_app/scheduler/frontend/dist
		try_files {path} /index.html
		file_server
	}

	# === study ===
	handle /study/api/* {
		uri strip_prefix /study
		reverse_proxy localhost:3001
	}
	handle_path /study/* {
		root * /srv/life_app/study/frontend/dist
		try_files {path} /index.html
		file_server
	}

	# === shift ===
	handle /shift/api/* {
		uri strip_prefix /shift
		reverse_proxy localhost:3002
	}
	handle_path /shift/* {
		root * /srv/life_app/shift/frontend/dist
		try_files {path} /index.html
		file_server
	}
}
