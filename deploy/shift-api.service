[Unit]
Description=Shift API (Hono backend)
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=simple
User=lifeapp
WorkingDirectory=/srv/life_app/shift/backend
EnvironmentFile=/srv/life_app/shift/backend/.env
ExecStart=/usr/bin/env node /srv/life_app/shift/backend/dist/index.js
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
